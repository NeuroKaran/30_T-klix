# =============================================================================
# Nemo - Real-time AI Companion Backend
# Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Groq API (Required for LLM)
# Get your API key at: https://console.groq.com/
# -----------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# Groq Model Selection
# Options: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# Mem0 API (Required for Memory/Personalization)
# Get your API key at: https://app.mem0.ai/
# -----------------------------------------------------------------------------
MEM0_API_KEY=your_mem0_api_key_here
MEMORY_ENABLED=true

# User identifier for memory storage
NEMO_USER_ID=user_default

# -----------------------------------------------------------------------------
# TTS Configuration (Edge-TTS - No API key needed!)
# -----------------------------------------------------------------------------
# Voice options:
# - en-IN-NeerjaNeural (Indian English, warm)
# - en-IN-NeerjaExpressiveNeural (Indian English, expressive)
# - en-US-AriaNeural (US English)
# - en-US-JennyNeural (US English)
# - en-GB-SoniaNeural (British English)
TTS_VOICE=en-IN-NeerjaExpressiveNeural

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated for multiple)
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Optional: Deepgram (for Speech-to-Text if needed in future)
# Get your API key at: https://deepgram.com/
# -----------------------------------------------------------------------------
# DEEPGRAM_API_KEY=your_deepgram_api_key_here
